import random
import time

# Accept minimum and maximum temperature limits
min_temp = float(input("Enter minimum temperature limit: "))
max_temp = float(input("Enter maximum temperature limit: "))
if min_temp>max_temp:
    print("Error: minimum temperature must be less then maximum temperature")
else:
    print("\nTemperature Monitoring Started...\n")

# Generate temperature every 2 seconds
    for i in range(5):   # runs 10 times (you can change)
        temp = random.randint(0, 100)   # random temperature 0–100

        print("Current Temperature:", temp)

    # Compare with limits
        if temp > max_temp:
            print("Alert: Temperature is too high")
        elif temp < min_temp:
            print("Alert: Temperature is too low")
        else:
            print("Temperature is normal")

        print("--------------------------")
        time.sleep(2)   # wait for 2 seconds
    
